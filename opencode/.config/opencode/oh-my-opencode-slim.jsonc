// NOTE: bunx oh-my-opencode-slim@latest install --no-tui --skills=yes --companion=no
{
  "$schema": "https://unpkg.com/oh-my-opencode-slim@latest/oh-my-opencode-slim.schema.json",
  "autoUpdate": true,
  "disabled_mcps": [ // don't need these mcps carried by oh-my-opencode-slim, had been enabled in opencode.json
    "websearch",
    "context7",
    "gh_grep"
  ],
  "preset": "a-team",
  "presets": {
    "a-team": {
      "orchestrator": {
        "model": [
          {
            "id": "9router/cx/gpt-5.6-terra"
          },
          {
            "id": "9router/ocg/glm-5.2"
          }
        ],
        "skills": [
          "*"
        ],
        "mcps": []
      },
      "oracle": {
        "model": [
          {
            "id": "9router/cc/claude-opus-4-8(high)"
          },
          {
            "id": "9router/cx/gpt-5.6-sol(high)"
          }
        ],
        "skills": [
          "simplify"
        ],
        "mcps": []
      },
      "librarian": {
        "model": [
          {
            "id": "9router/ocg/deepseek-v4-flash"
          },
          {
            "id": "9router/cx/gpt-5.4-mini(low)"
          }
        ],
        "skills": [],
        "mcps": [
          "context7",
          "gh_grep"
        ]
      },
      "explorer": {
        "model": [
          {
            "id": "9router/cc/claude-sonnet-5(low)"
          },
          {
            "id": "9router/cx/gpt-5.6-luna(low)"
          }
        ],
        "skills": [],
        "mcps": []
      },
      "designer": {
        "model": [
          {
            "id": "9router/cx/gpt-5.6-terra(medium)"
          },
          {
            "id": "9router/ocg/kimi-k2.7-code"
          }
        ],
        "skills": [],
        "mcps": []
      },
      "fixer": {
        "model": [
          {
            "id": "9router/cc/claude-sonnet-5(low)"
          },
          {
            "id": "9router/ocg/kimi-k2.7-code"
          }
        ],
        "skills": [],
        "mcps": []
      }
    }
  },
  "companion": {
    "enabled": false, // installed path ~/.local/share/opencode/storage/oh-my-opencode-slim
    "position": "bottom-right",
    "size": "medium",
    "gifPack": "default",
    "loopStyle": "classic",
    "speed": 1,
    "debug": false
  },
  "multiplexer": {
    "type": "none", // set to tmux and start "opencode --port PORT" to expose server, that subagent session can be attached to the server
    "layout": "main-vertical",
    "main_pane_size": 60
  }
}
