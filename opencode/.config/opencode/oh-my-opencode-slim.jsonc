{
  "$schema": "https://unpkg.com/oh-my-opencode-slim@latest/oh-my-opencode-slim.schema.json",
  "autoUpdate": true,
  "disabled_mcps": [ // don't need these mcps carried by oh-my-opencode-slim, had been enabled in opencode.json
    "websearch",
    "context7",
    "gh_grep"
  ],
  "preset": "a-team",
  "presets": {
    "a-team": {
      "orchestrator": {
        "model": [
          {
            "id": "openai/gpt-5.5"
          },
          {
            "id": "opencode-go/glm-5.2"
          }
        ],
        "skills": [
          "*"
        ],
        "mcps": []
      },
      "oracle": {
        "model": [
          {
            "id": "opencode-go/glm-5.2",
            "variant": "high"
          },
          {
            "id": "openai/gpt-5.5",
            "variant": "high"
          }
        ],
        "skills": [
          "simplify"
        ],
        "mcps": []
      },
      "librarian": {
        "model": [
          {
            "id": "opencode-go/deepseek-v4-flash",
            "variant": "low"
          },
          {
            "id": "openai/gpt-5.4-mini-fast",
            "variant": "low"
          }
        ],
        "skills": [],
        "mcps": [
          "context7",
          "gh_grep"
        ]
      },
      "explorer": {
        "model": [
          {
            "id": "opencode-go/kimi-k2.6",
            "variant": "low"
          },
          {
            "id": "openai/gpt-5.4-mini-fast",
            "variant": "low"
          }
        ],
        "skills": [],
        "mcps": []
      },
      "designer": {
        "model": [
          {
            "id": "opencode-go/kimi-k2.7-code",
            "variant": "medium"
          },
          {
            "id": "openai/gpt-5.5",
            "variant": "medium"
          }
        ],
        "skills": [],
        "mcps": []
      },
      "fixer": {
        "model": [
          {
            "id": "opencode-go/kimi-k2.7-code",
            "variant": "low"
          },
          {
            "id": "openai/gpt-5.5",
            "variant": "low"
          }
        ],
        "skills": [],
        "mcps": []
      }
    }
  },
  "companion": {
    "enabled": false, // installed path ~/.local/share/opencode/storage/oh-my-opencode-slim
    "position": "bottom-right",
    "size": "medium",
    "gifPack": "default",
    "loopStyle": "classic",
    "speed": 1,
    "debug": false
  },
  "multiplexer": {
    "type": "none", // set to tmux and start "opencode --port PORT" to expose server, that subagent session can be attached to the server
    "layout": "main-vertical",
    "main_pane_size": 60
  }
}
