{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "plan",
  "agent": {
    "plan": {
      "color": "secondary",
      "model": "openai/gpt-5.5"
      // "model": "opencode-go/glm-5.2"
    },
    "build": {
      "color": "error",
      "model": "openai/gpt-5.5"
      // "model": "opencode-go/glm-5.2"
    },
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    }
  },
  "lsp": false,
  "mcp": {
    "openpets": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@open-pets/cli@2.0.7",
        "mcp",
        "--pet",
        "cinnamonroll"
      ],
      "enabled": true
    },
    "tw-591": {
      "type": "local",
      "command": [
        "mcp-591"
      ],
      "enabled": false
    },
    "tw-company": {
      "type": "local",
      "command": [
        "uv",
        "tool",
        "run",
        "mcp-tw-company"
      ],
      "enabled": false
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
      "headers": {
        "CONTEXT7_API_KEY": "{file:secrets/context7}"
      }
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": true
    }
  },
  "instructions": [
    "openpets.md"
  ],
  "plugin": [
    "opencode-gpt-imagegen@v0.1.8",
    [
      "@open-pets/opencode@2.0.7",
      {
        "pet": "cinnamonroll"
      }
    ],
    "oh-my-opencode-slim"
  ]
}
