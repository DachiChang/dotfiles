{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "orchestrator",
  "provider": {
    "9router": {
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:20128/v1",
        "apiKey": "{file:secrets/9router}"
      },
      "models": {
        "cx/gpt-5.6-sol": {
          "name": "GPT-5.6 Sol"
        },
        "cx/gpt-5.6-terra": {
          "name": "GPT-5.6 Terra"
        },
        "cx/gpt-5.6-luna": {
          "name": "GPT-5.6 Luna"
        },
        "cc/claude-fable-5": {
          "name": "Claude Fable 5"
        },
        "cc/claude-sonnet-5": {
          "name": "Claude Sonnet 5"
        },
        "cc/claude-opus-4-8": {
          "name": "Claude Opus 4.8"
        },
        "cx/gpt-5.4-mini": {
          "name": "GPT-5.4 Mini"
        },
        "ocg/glm-5.2": {
          "name": "GLM 5.2"
        },
        "ocg/kimi-k2.7-code": {
          "name": "Kimi K2.7 Code"
        },
        "ocg/kimi-k2.6": {
          "name": "Kimi K2.6"
        },
        "ocg/deepseek-v4-pro": {
          "name": "DeepSeek V4 Pro"
        },
        "ocg/deepseek-v4-flash": {
          "name": "DeepSeek V4 Flash"
        },
        "ocg/mimo-v2.5-pro": {
          "name": "MiMo V2.5 Pro"
        },
        "ocg/minimax-m3": {
          "name": "MiniMax M3"
        },
        "ocg/qwen3.7-max": {
          "name": "Qwen 3.7 Max"
        }
      }
    }
  },
  "agent": {
    "orchestrator": {
      "color": "success"
    },
    "plan": {
      "color": "secondary",
      "model": "9router/cc/claude-opus-4-8",
      // "model": "9router/cx/gpt-5.6-sol"
      // "model": "9router/ocg/glm-5.2"
      "permission": {
        "task": "deny"
      }
    },
    "build": {
      "color": "error",
      "model": "9router/cc/claude-opus-4-8",
      // "model": "9router/cx/gpt-5.6-sol"
      // "model": "9router/ocg/glm-5.2"
      "permission": {
        "task": "deny"
      }
    },
    "title": {
      "model": "9router/cx/gpt-5.4-mini"
    },
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    }
  },
  "lsp": false,
  "skills": {
    "paths": [
      "~/skills"
    ]
  },
  "mcp": {
    "openpets": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@open-pets/cli@2.0.7",
        "mcp",
        "--pet",
        "cinnamonroll"
      ],
      "enabled": true
    },
    "tw-591": {
      "type": "local",
      "command": [
        "mcp-591"
      ],
      "enabled": false
    },
    "tw-company": {
      "type": "local",
      "command": [
        "uv",
        "tool",
        "run",
        "mcp-tw-company"
      ],
      "enabled": false
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
      "headers": {
        "CONTEXT7_API_KEY": "{file:secrets/context7}"
      }
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": true
    }
  },
  "instructions": [
    "openpets.md"
  ],
  "plugin": [
    "opencode-gpt-imagegen@v0.1.8",
    [
      "@open-pets/opencode@2.0.7",
      {
        "pet": "cinnamonroll"
      }
    ],
    "oh-my-opencode-slim"
  ]
}
