{
  "$schema": "https://opencode.ai/tui.json",
  "theme": "custom-gruvbox",
  "keybinds": {
    "leader": false,
    "command_list": "ctrl+o",
    "session_child_first": "ctrl+]",
    "session_child_cycle": "]",
    "session_child_cycle_reverse": "[",
    "session_parent": "backspace",
    "session_new": "ctrl+n",
    "session_list": "ctrl+l",
    "session_timeline": "ctrl+g",
    "session_fork": "ctrl+f",
    "model_list": "ctrl+s"
  },
  "plugin": ["oh-my-opencode-slim"]
}
