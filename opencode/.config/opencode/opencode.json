{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "ask",
  "agent": {
    "plan": {
      "model": "openai/gpt-5.4"
    },
    "build": {
      "model": "openai/gpt-5.3-codex"
    }
  },
  "mcp": {
    "tw-company": {
      "type": "local",
      "command": ["uv", "tool", "run", "mcp-tw-company"],
      "enabled": false
    },
    "tw-lvr": {
      "type": "local",
      "command": ["uv", "tool", "run", "mcp-tw-lvr"],
      "enabled": false
    },
    "google-drive": {
      "type": "local",
      "command": ["npx", "@piotr-agier/google-drive-mcp"],
      "environment": {
        "GOOGLE_DRIVE_OAUTH_CREDENTIALS": "/Users/dachichang/dotfiles/opencode/.config/opencode/gcp-oauth.keys.json"
      },
      "enabled": false
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
      "headers": {
        "CONTEXT7_API_KEY": "ctx7sk-d8992a46-2bf4-4a9d-bd4a-936c5e32165a"
      }
    }
  }
}
