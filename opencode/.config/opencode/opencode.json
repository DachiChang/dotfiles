{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "ask",
  "agent": {
    "plan": {
      "model": "openai/gpt-5.5"
    },
    "build": {
      "model": "opencode/big-pickle"
    }
  },
  "lsp": false,
  "mcp": {
    "openpets": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@open-pets/cli@2.0.7",
        "mcp",
        "--pet",
        "cinnamonroll"
      ],
      "enabled": true
    },
    "tw-591": {
      "type": "local",
      "command": ["mcp-591"],
      "enabled": false
    },
    "tw-company": {
      "type": "local",
      "command": ["uv", "tool", "run", "mcp-tw-company"],
      "enabled": false
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
      "headers": {
        "CONTEXT7_API_KEY": "ctx7sk-d8992a46-2bf4-4a9d-bd4a-936c5e32165a"
      }
    }
  },
  "instructions": [
    "openpets.md"
  ],
  "plugin": [
    [
      "@open-pets/opencode@2.0.7",
      {
        "pet": "cinnamonroll"
      }
    ]
  ]
}
