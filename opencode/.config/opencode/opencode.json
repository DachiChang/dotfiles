{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "plan",
  "mcp": {
    "google-drive": {
      "type": "local",
      "command": ["npx", "@piotr-agier/google-drive-mcp"],
      "environment": {
        "GOOGLE_DRIVE_OAUTH_CREDENTIALS": "/Users/dachichang/dotfiles/opencode/.config/opencode/gcp-oauth.keys.json"
      },
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest"],
      "environment": {},
      "enabled": true
    },
    "kubernetes": {
      "type": "local",
      "command": ["npx", "-y", "mcp-server-kubernetes"],
      "enabled": true,
      "environment": {}
    },
    "postgres": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-postgres", "postgresql://"],
      "enabled": true,
      "environment": {}
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
      "headers": {
        "CONTEXT7_API_KEY": ""
      }
    }
  },
}
